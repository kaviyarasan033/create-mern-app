# --- Core Application ---
APP_NAME=MERN MVC Starter
APP_ENV=local
APP_DEBUG=true
PORT=5000
APP_URL=http://localhost:5000

# --- Database ---
DB_CONNECTION=mongodb
DB_MONGO_HOST=127.0.0.1
DB_MONGO_PORT=27017
DB_MONGO_DATABASE=mern_mvc_starter
MONGODB_URI=mongodb://${DB_MONGO_HOST}:${DB_MONGO_PORT}/${DB_MONGO_DATABASE}

# --- Authentication ---
JWT_SECRET=change_this_secret_before_production
JWT_EXPIRE=30d

# --- Security ---
RATE_LIMIT_MAX=100
CORS_ALLOWED_ORIGINS=http://localhost:3000

# --- Logging ---
LOG_LEVEL=info
