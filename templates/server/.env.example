# --- Core Application ---
APP_NAME=ProApp
APP_ENV=local
APP_KEY=base64:7vF6zqLp/W/8x9R0mY9bV5Zc3D2E1F0G=
APP_DEBUG=true
APP_URL=http://localhost:5000

# --- Database Selection ---
# Set to 'mongodb' or 'mysql'
DB_CONNECTION=mongodb

# --- MongoDB Configuration ---
DB_MONGO_HOST=127.0.0.1
DB_MONGO_PORT=27017
DB_MONGO_DATABASE=proapp_db
MONGODB_URI=mongodb://${DB_MONGO_HOST}:${DB_MONGO_PORT}/${DB_MONGO_DATABASE}

# --- MySQL Configuration (Knex) ---
DB_MYSQL_HOST=127.0.0.1
DB_MYSQL_PORT=3306
DB_MYSQL_USER=root
DB_MYSQL_PASSWORD=
DB_MYSQL_DATABASE=proapp_db

# --- Firebase Configuration ---
FIREBASE_PROJECT_ID=
FIREBASE_PRIVATE_KEY_ID=
FIREBASE_PRIVATE_KEY=
FIREBASE_CLIENT_EMAIL=
FIREBASE_CLIENT_ID=

# --- Authentication ---
JWT_SECRET=yoursupersecretkeyhere
JWT_EXPIRE=30d

# --- Mail Configuration ---
MAIL_DRIVER=smtp
MAIL_HOST=smtp.mailtrap.io
MAIL_PORT=2525
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_ENCRYPTION=tls
MAIL_FROM_ADDRESS=hello@proapp.com

# --- Redis Cache ---
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

# --- CORS ---
CORS_ALLOWED_ORIGINS=http://localhost:3000
