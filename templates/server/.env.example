# --- Core Application ---
APP_NAME=MERN MVC Starter
APP_ENV=local
APP_DEBUG=true
PORT=5000
APP_URL=http://localhost:5000

# --- Database ---
DB_CONNECTION=mongodb
DB_MONGO_URI=
DB_MONGO_URL=
DB_MONGO_DATABASE=mern_mvc_starter
DB_MONGO_USERNAME=
DB_MONGO_PASSWORD=

# --- Optional MySQL Integration ---
MYSQL_ENABLED=false
MYSQL_HOST=127.0.0.1
MYSQL_PORT=3306
MYSQL_USER=root
MYSQL_PASSWORD=
MYSQL_DATABASE=mern_mvc_tools
MYSQL_CONNECTION_LIMIT=10

# --- Authentication ---
JWT_SECRET=change_this_secret_before_production
JWT_EXPIRE=30d

# --- Optional Firebase Admin ---
FIREBASE_ENABLED=false
FIREBASE_PROJECT_ID=
FIREBASE_CLIENT_EMAIL=
FIREBASE_PRIVATE_KEY=
FIREBASE_STORAGE_BUCKET=
FIREBASE_DATABASE_URL=

# Firebase Client Configuration (for Google OAuth)
FIREBASE_API_KEY=
FIREBASE_AUTH_DOMAIN=
FIREBASE_MESSAGING_SENDER_ID=
FIREBASE_APP_ID=
FIREBASE_MEASUREMENT_ID=

# --- Security ---
RATE_LIMIT_MAX=100
CORS_ALLOWED_ORIGINS=http://localhost:3000

# --- Logging ---
LOG_LEVEL=info
